{
  "DatabaseProvider": "postgresql",
  "ConnectionStrings": {
    "PreOddsApiPostgresDb": "Host=localhost;Port=5432;Database=preodds;Username=preodds;Password=preodds_dev_password"
  },
  "Logging": {
    "Logpath": "Logs/Api_logs.txt",
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "SportMonks": {
    "BaseUrl": "https://api.sportmonks.com",
    "Version": "v3",
    "Sport": "football",
    "ApiToken": "",
    "DefaultPerPage": 50,
    "TimeoutSeconds": 30,
    "MaxRetries": 3,
    "UseAuthorizationHeader": true
  },
  "SportMonksUrls": {
    "fixtureByDate": "fixtures/date/",
    "fixtureByDateRange": "fixtures/between/",
    "preMatchNews": "news/pre-match",
    "preMatchNewsUpcoming": "news/pre-match/upcoming",
    "postMatchNews": "news/post-match"
  },
  "SportMonksWorkerSettings": {
    "_comment": "Three-tier scheduler: Live ticks every LiveIntervalSeconds, Pulse every PulseIntervalSeconds, Nightly every NightlyIntervalSeconds. Each individual job has its own *IntervalSeconds gate that must elapse before the job actually runs inside its tier.",

    "LiveIntervalSeconds": 30,
    "PulseIntervalSeconds": 1800,
    "NightlyIntervalSeconds": 86400,

    "FixtureLiveIntervalSeconds": 30,
    "FixtureBacklogIntervalSeconds": 86400,
    "InplayOddsIntervalSeconds": 30,
    "PrematchOddsIntervalSeconds": 1800,
    "NewsIntervalSeconds": 1800,
    "StandingsIntervalSeconds": 1800,
    "ReferenceDataIntervalSeconds": 86400,
    "TransfersIntervalSeconds": 86400,
    "TvStationsIntervalSeconds": 86400,
    "AnalyticsIntervalSeconds": 86400
  },
  "SportMonksFixtureLiveSync": {
    "Enabled": false,
    "DaysBack": 0,
    "DaysForward": 0,
    "Timezone": "UTC",
    "_comment": "Today-only window pulled on every Live tick to keep score / events / lineups fresh during a match."
  },
  "SportMonksFixtureBacklogSync": {
    "Enabled": false,
    "DaysBack": 2,
    "DaysForward": 14,
    "Timezone": "UTC",
    "_comment": "Wider window walked once per Nightly tick. Backfills finished matches so analytics has settled odds + final scores."
  },
  "SportMonksPlayerReferenceSync": {
    "Enabled": false,
    "SyncPlayers": true,
    "SyncCoaches": true,
    "SyncRivals": true,
    "SyncTeamSquads": false,
    "MaxSquadTeamsPerRun": 0
  },
  "SportMonksStandingSync": {
    "Enabled": false,
    "SyncStandings": true,
    "SyncTopScorers": true,
    "CurrentSeasonsOnly": true,
    "MaxSeasonsPerRun": 0
  },
  "SportMonksTransferSidelinedSync": {
    "Enabled": false,
    "SyncLatestTransfers": true,
    "TransferOrder": "desc",
    "SyncFixtureSidelined": false
  },
  "SportMonksFixtureMediaWeatherSync": {
    "Enabled": false,
    "SyncTvStations": true,
    "TvStationOrder": "asc",
    "SyncTvStationCountries": true,
    "SyncFixtureTvStations": false,
    "SyncWeatherReports": false
  },
  "SportMonksFixtureTimelineSync": {
    "Enabled": false,
    "SyncTrends": false,
    "SyncPressureTrends": false,
    "SyncCommentaries": false
  },
  "SportMonksPrematchOddsSync": {
    "Enabled": false,
    "SyncFixtureOdds": true,
    "SyncLatestOdds": false,
    "IncludeMarket": true,
    "IncludeBookmaker": true,
    "RecordHistory": true,
    "_comment": "Set Enabled=true to sync prematch odds via fixture include. SyncLatestOdds requires a paid plan. IncludeMarket/IncludeBookmaker work on the free plan via fixtures/date — verified."
  },
  "AnalyticsSync": {
    "Enabled": false,
    "RunSeasonStats": true,
    "RunSeasonTeamStats": true,
    "RunOddAnalysisSnapshots": true,
    "RunFixtureSignals": true,
    "RunRateResults": true
  },
  "SportMonksInplayOddsSync": {
    "Enabled": false,
    "SyncLatestOdds": true,
    "RecordHistory": true,
    "RequestDelayMs": 1000
  },
  "SportMonksNewsSync": {
    "Enabled": false,
    "SyncAllPreMatchNews": false,
    "SyncUpcomingPreMatchNews": false,
    "SyncAllPostMatchNews": false,
    "SyncFixturePreMatchNews": false,
    "SyncFixturePostMatchNews": false,
    "IncludeLines": true,
    "Order": "desc"
  }
}
