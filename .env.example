# Base URL for the PreOddsApi V3 backend.
# Variables prefixed with EXPO_PUBLIC_ are inlined into the JS bundle at build time.
#
# Pick the value that matches where you run the app:
#   - Android emulator (host's localhost): http://10.0.2.2:28333
#   - iOS simulator:                       http://localhost:28333
#   - Physical device on same Wi-Fi:       http://<your-LAN-IP>:28333
#
# The path /api/v3 is appended by the API client.
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:28333
