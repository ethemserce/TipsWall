# Optional override for the PreOddsApi V3 backend base URL.
#
# Leave empty to use platform-aware defaults:
#   - Android emulator: http://10.0.2.2:28333
#   - iOS sim, web, desktop: http://localhost:28333
#
# Set explicitly when running on a physical device or against a remote backend.
# The path /api/v3 is appended automatically by the API client.
#
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:28333
