# Production env file. Copy to /opt/tipswall/.env on the VPS and fill
# in the secrets. Never commit a real .env to git.
#
# Notes:
#  - GHCR_OWNER must match the GitHub user/org that owns the
#    container images (lowercase). Example: GHCR_OWNER=ethemserce.
#  - IMAGE_TAG defaults to "latest"; the deploy workflow also pushes
#    a commit-SHA tag so you can roll back if needed.
#  - POSTGRES_DATA_DIR points at the Hetzner Volume mount.

# --- Image registry --------------------------------------------------
GHCR_OWNER=ethemserce
IMAGE_TAG=latest

# --- Domain ---------------------------------------------------------
DOMAIN=api.tipswall.com

# --- Marketing / legal host(s) --------------------------------------
# Hostnames that should serve the static /privacy and /terms pages
# (referenced from the Play Store listing). Multiple hostnames are
# space-separated. Caddy will provision a Let's Encrypt cert for each.
# Point the A records at this VPS first, then set this env var.
# Leave commented to keep legal pages only on the API host.
# LEGAL_DOMAINS=tipswall.com www.tipswall.com

# --- Postgres -------------------------------------------------------
POSTGRES_USER=preodds
POSTGRES_DB=preodds
POSTGRES_PASSWORD=__CHANGE_ME__
# Bind-mount the Hetzner Volume so the data survives container
# replacements. The path is the mount point on the host, not inside
# the container.
POSTGRES_DATA_DIR=/mnt/tipswall-data/postgres

# --- WebAPI ---------------------------------------------------------
# Generate with: openssl rand -base64 48
PREODDS_JWT_SECRET=__CHANGE_ME_AT_LEAST_32_CHARS__
# Optional admin shared secret for internal endpoints. Leave blank
# if unused.
PREODDS_INTERNAL_API_KEY=
AUTH_ISSUER=https://api.tipswall.com
AUTH_AUDIENCE=https://api.tipswall.com
# CORS allowlist — comma-separated list of origins that may call the
# API directly from a browser. Add the marketing site origin when it
# ships.
CORS_ORIGIN_0=https://tipswall.com

# --- SportMonks -----------------------------------------------------
SPORTMONKS_API_TOKEN=__SET_FROM_SPORTMONKS_DASHBOARD__

# --- Social sign-in (optional, leave blank until configured) ---------
PREODDS_APPLE_CLIENT_ID=
PREODDS_GOOGLE_CLIENT_ID_IOS=
PREODDS_GOOGLE_CLIENT_ID_ANDROID=
PREODDS_GOOGLE_CLIENT_ID_WEB=

# --- Sentry (optional) ----------------------------------------------
SENTRY_DSN_BACKEND=

# --- Mail (admin alerts; GoDaddy Pro Email) -------------------------
# Used by the worker's nightly snapshot tier to email an admin when
# the rebuild fails twice. Leave MAIL_PASSWORD blank to disable mail
# (failures still log to Serilog + Sentry).
MAIL_HOST=smtpout.secureserver.net
MAIL_PORT=465
MAIL_USERNAME=tipswall@tipswall.com
MAIL_PASSWORD=__SET_FROM_GODADDY_MAILBOX_PASSWORD__
MAIL_FROM=tipswall@tipswall.com
MAIL_FROM_NAME=TipsWall Ops
NIGHTLY_SNAPSHOT_ADMIN_EMAIL=ethemserce@gmail.com

# --- Season backfill (one-shot historical sync) ---------------------
# Flip ENABLED=true and set FROM/TO to a date range (UTC, YYYY-MM-DD).
# The worker walks past dates day-by-day on the live tick to populate
# fixtures + odds. Idempotent — restart-safe; already-done days are
# skipped via sync.job_runs checkpoints. After the window completes,
# the analytics finalizer + odd-analysis snapshot rebuild fire
# automatically so HIT/ROI come alive without waiting for 03:00 UTC.
#
# Flip back to false (and optionally clear sync.job_runs rows whose
# job_key starts with "season.backfill:") when you want to re-run.
SEASON_BACKFILL_ENABLED=false
SEASON_BACKFILL_FROM=
SEASON_BACKFILL_TO=
SEASON_BACKFILL_DAYS_PER_TICK=2
