# Copy this file to .env and fill in real secrets before running:
#   docker compose -f docker-compose.production.yml --env-file .env up -d --build

# PostgreSQL
POSTGRES_USER=preodds
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=preodds

# WebApi external port
WEBAPI_PORT=8080

# JWT
PREODDS_JWT_SECRET=CHANGE_ME_at_least_32_characters_long_secret
AUTH_ISSUER=http://localhost:8080
AUTH_AUDIENCE=http://localhost:8080

# Internal API key (legacy V1/V2 endpoints)
PREODDS_INTERNAL_API_KEY=

# SportMonks API token (workers use this; leave empty to disable sync)
SPORTMONKS_API_TOKEN=
