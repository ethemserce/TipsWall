                                            <li class="nav-item" role="presentation" style="border-top:1px solid #e1e1e1;"><a class="nav-link" href="#tabs-hth" data-toggle="tab" style="padding:7px; min-width:100px;">@SharedLocalizer.GetString("Hth")</a></li>
