@section scripts {
    <script src="/vendor/jsrender/jsrender.min.js"></script>

    <script id="fixtureTemplate" type="text/x-jsrender">
                <article class="heading-component">
                    <div class="heading-component-inner">
                        {{if country != null}}
                        <h5 class="heading-component-title">
                            <img src="{{:country.logo}}" alt="" width="24" height="24" /> {{:country.name}}
                        </h5>
                        <span style="float:right;"> <a href="/leagueDetail/{{:league.id}}" target="_blank">  <img src="{{:league.logo}}" alt="" width="24" height="24" /> {{:league.name}}</a></span>
                        {{else}}
                        <h5 class="heading-component-title">
                            <a href="/leagueDetail/{{:league.id}}" target="_blank">    <img src="{{:league.logo}}" alt="" width="24" height="24" /> {{:league.name}}</a>
        </h5>
                        {{/if}}
                    </div>
                </article>
                <article class="game-result">
                    <div class="game-info game-info-classic" style="padding:10px;">
                        <span style="float:left;"> @SharedLocalizer.GetString("WeatherForecast"): <img src="{{:weatherIcon}}" alt="" width="32" height="32" /><span> {{:weatherCode}}</span></span>
                        <span style="float:right;"> @SharedLocalizer.GetString("Temparature"): {{:weatherTemperatureTemp}} °F / <span> {{:weatherTemperatureCelsiusTemp}}</span> °C</span>
                    </div>
                    <div class="game-info game-info-classic" style="padding:30px 10px 30px 10px;">
                        {{if venue != null && venue.name != null }}
                        <p class="game-info-subtitle">

        @SharedLocalizer.GetString("Stadium"): {{:venue.name}}

        @*<time datetime="2018-04-17"> {{:timeStartingAtDateTime}}</time>*@
                        </p>
                        {{/if}}

        @*<p class="game-info-subtitle">
                            <time datetime="2018-04-17" style="padding-top:25px;"> {{:timeStartingAtDate}}</time>
                        </p>*@
        @*<h3 class="game-info-title"><img src="{{:country.logo}}" alt="" width="36" height="36" /> {{:country.name}} - {{:league.name}}</h3>*@
                        <div class="game-info-main">
                            <div class="game-info-team game-info-team-first">
                                <figure>
                                                      {{if localTeam != null}}      <img src="{{:localTeam.logoPath}} " alt="" width="64" height="64" />{{/if}}
                                </figure>
                                <div class="game-result-team-name">{{:localTeam.name}}</div>
                                {{if localTeamCoach != null}}
                                <div class="game-result-team-country">{{:localTeamCoach.commonName}}</div>
                                {{/if}}
                                <div class="game-result-team-country" style="display: flex; justify-content: center;">
                                    {{if localTeamForm != null}}
                                    {{props localTeamForm.split('')}}
                                    <span style="border:1px solid #808080; {{if prop == "L"}} background-color:#d0021b; color:#fff; {{else prop == "W"}} background-color:#2ba774; color:#fff;  {{else prop == "D"}} background-color:#ccc;  color:#2c2d31; {{/if}} width:1.225em; height:1.225em; margin: 1rem .125rem 0; font-size: .875rem;"> <span>  {{:prop}}</span> </span>
                                    {{/props}}
                                    {{/if}}
                                </div>
                            </div>
                            <div class="game-info-middle">
        @*<div class="game-result-score-wrap">
                                    <span class="text-danger" style="font-size:1.2em;">{{:timeMinute}} <span class="blink font-weight-bold">'</span> </span>
                                </div>*@
        @*<div class="game-result-score-wrap">
                                    <time datetime="2018-04-17" style="padding-top:25px;"> {{:timeStartingAtDate}}</time>
                                </div>
                                <div class="game-result-score-wrap" style="padding-top:0px;">
                                    <time datetime="2018-04-17" style="padding-top:5px;"> {{:timeStartingAtTime}}</time>
                                </div>*@
                                <p class="game-info-subtitle" style="padding-bottom:25px;">
                                    <time class="time-big" datetime="2018-04-17">
                                        <span class="heading-3">
                                            {{if timeStartingAtTime != null}}
                                            {{:timeStartingAtTime.substring(0,5)}}
                                            {{/if}}
                                            </span>
                                            {{:timeStartingAtDate}}
                                    </time>
                                </p>
                                <div class="game-result-score-wrap">
                                    {{if timeStatus != "NS"}}
                                    {{if localTeamScore > visitorTeamScore}}
                                    <div class="game-info-score game-result-team-win">{{:localTeamScore}}</div>
                                    <div class="game-info-score">{{:visitorTeamScore}}</div>
                                    {{else localTeamScore < visitorTeamScore}}
                                    <div class="game-info-score">{{:localTeamScore}}</div>
                                    <div class="game-info-score game-result-team-win">{{:visitorTeamScore}}</div>
                                    {{else}}
                                    <div class="game-info-score">{{:localTeamScore}}</div>
                                    <div class="game-info-score">{{:visitorTeamScore}}</div>
                                    {{/if}}
                                    {{/if}}
                                </div>
                                {{if timeStatus == "LIVE"}}
                                <div class="game-result-divider-wrap"><span class="game-info-team-divider" style="width:40px; height:40px; line-height: 37px;"><span class="text-danger" style="font-size:1.4em; padding-top:10px;"> {{:timeMinute}}<span class="blink font-weight-bold">'</span> </span></span></div>
                                {{else timeStatus == "ET"}}
                                <div class="game-result-divider-wrap"><span class="game-info-team-divider" style="width:40px; height:40px; line-height: 37px;"><span class="text-danger" style="font-size:1.4em; padding-top:10px;"> {{:timeMinute}}<span class="blink font-weight-bold">'</span> </span></span></div>
                                {{else timeStatus == "NS"}}
                                <div class="game-result-divider-wrap"><span class="game-info-team-divider">VS</span></div>
                                {{else}}
                                <div class="game-result-divider-wrap"><span class="game-info-team-divider">{{:timeStatus}}</span></div>
                                {{/if}}

                                {{if htScore != null}}
                                <p class="game-info-subtitle">
                                    <time datetime="2018-04-17" style="padding-top:25px;">@SharedLocalizer.GetString("HalfTimeShort"): {{:htScore}}</time>
                                </p>
                                {{/if}}

                                {{if timeInjuryTime > 0}}
                                <p class="game-info-subtitle">
                                    <time datetime="2018-04-17" style="padding-top:25px;">@SharedLocalizer.GetString("InjuryTime"): +{{:timeInjuryTime}}</time>
                                </p>
                                {{/if}}
                                {{if timeAddedTime > 0}}
                                <p class="game-info-subtitle">
                                    <time datetime="2018-04-17" style="padding-top:25px;"> + {{:timeAddedTime}}</time>
                                </p>
                                {{/if}}
                            </div>
                            <div class="game-info-team game-info-team-second">
                                <figure>
                                    <img src="{{:visitorTeam.logoPath}}" alt="" width="77" height="70" />
                                </figure>
                                <div class="game-result-team-name">{{:visitorTeam.name}}</div>
                                {{if visitorTeamCoach != null}}
                                <div class="game-result-team-country">{{:visitorTeamCoach.commonName}}</div>
                                {{/if}}
                                <div class="game-result-team-country" style="display: flex; justify-content: center;">
                                    {{if visitorTeamForm != null}}
                                    {{props visitorTeamForm.split('')}}
                                    <span style="border:1px solid #808080; {{if prop == "L"}} background-color:#d0021b; color:#fff; {{else prop == "W"}} background-color:#2ba774; color:#fff;  {{else prop == "D"}} background-color:#ccc;  color:#2c2d31; {{/if}} width:1.225em; height:1.225em; margin: 1rem .125rem 0; font-size: .875rem;"> <span>  {{:prop}}</span> </span>
                                    {{/props}}
                                    {{/if}}
                                </div>

                            </div>
                        </div>
                    </div>
                    <div class="game-info game-info-classic" style="padding:10px 10px 30px 10px; text-align:center;">
                        <span style="float:left;"> @SharedLocalizer.GetString("Clouds"):  {{:weatherClouds}}</span>
        @*<span> @SharedLocalizer.GetString("WindDegree"): {{:weatherWindDegree}}°</span>
                        <span style="float:right"> @SharedLocalizer.GetString("WindSpeed") :  {{:weatherWindSpeed}}</span>*@
                        <span style="float:right"> @SharedLocalizer.GetString("WindDegree"): {{:weatherWindDegree}} / {{:weatherWindSpeed}}</span>
                    </div>
                </article>

    </script>
    <script id="standingBaseTemplate" type="text/x-jsrender">
        {{if standing.length > 0}}
        {{for standing }}
        {{if #parent.parent.data.localTeamId == standingsTeamId}}
        <tr style="background-color:#77af0026;">
            {{else #parent.parent.data.visitorTeamId == standingsTeamId}}
        <tr style="background-color:#e75a3c17;">
            {{else}}
        <tr>
            {{/if}}
            <td><span>{{:standingsPositon}}</span></td>
            <td class="team-inline">
                <div class="team-figure">
                    <img src="{{:team.logoPath}}" alt="" width="25" height="25" />
                </div>
                <div class="team-title">
                    <div class="team-name">{{:team.name}}</div>
                    <div class="team-country">{{:team.shortCode}}</div>
                </div>
            </td>
            <td>{{:standingsOverallGamesPlayed}}</td>
            <td>{{:standingsOverallWon}}</td>
            <td>{{:standingsOverallDraw}}</td>
            <td>{{:standingsOverallLost}}</td>
            <td>{{:standingsTotalPoints}}</td>
        </tr>
        {{/for}}
        {{else}}
        @SharedLocalizer.GetString("NoData")
        {{/if}}
    </script>
    <script id="standingTemplate" type="text/x-jsrender">

    </script>
    <script id="statisticsTemplate" type="text/x-jsrender">
        <div class="col-lg-12" style="padding-bottom:15px;">
            <div class="statistics-interrelation">
                <div class="statistics-interrelation-header">
                    {{if type == 'ball-possession'}}{{:typeName}}{{/if}}
                </div>
                <div class="statistics-interrelation-body">
                    <div class="statistics-interrelation-body-list">
                        <div class="statistics-interrelation-body-item">
                            <div class="statistics-interrelation-body-item-block">
                                <span class="statistics-interrelation-body-item-block-procent">
                                   
                                                    {{if type == 'ball-possession'}}
                                                        {{:localTeamValue}}%
                                                         {{/if}}
                                    
            
                                    </span>
                                    <span class="statistics-interrelation-body-item-block-text">
                                                    
                                                {{:localTeamName}}
                                                        

                                        </span>
                                        </div>
                        </div>

                        <div class="statistics-interrelation-body-item">
                            <div class="statistics-interrelation-body-item-block statistics-interrelation-body-item-block-primary">
                                <span class="statistics-interrelation-body-item-block-procent">
                                           {{if type == 'ball-possession'}}
                                                                {{:visitorTeamValue}}%
                                                                 {{/if}}
                                    </span>
                                    <span class="statistics-interrelation-body-item-block-text">
                                        {{:visitorTeamName}}
                                        </span>
                                        </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="table-game-info-wrap">
            <span class="table-game-info-title">@SharedLocalizer.GetString("Shots")<span></span></span>
            <div class="table-game-info-main table-custom-responsive">
                <table class="table-custom table-game-info" style="border-spacing:0 2px;">
