                        {{if timeStatus != "NS" && timeStatus != "TBA"}}
                        <div class="match-table-score" style="text-align: center; font-size: 1.5em;">
                            <span {{if localTeamScore > visitorTeamScore}} style="color:#64b000;" {{else localTeamScore < visitorTeamScore}} style="color:#ff4f2e;" {{/if}}>{{:localTeamScore}}</span> <span>:</span> <span {{if visitorTeamScore > localTeamScore}} style="color:#64b000;" {{else visitorTeamScore < localTeamScore}} style="color:#ff4f2e;" {{/if}}>{{:visitorTeamScore}}</span>
                        </div>
                        {{/if}}
                        {{if timeStatus == "TBA"}}
                        <div class="match-table-time" style="text-align: center; font-size: 0.95em;"><span>{{:timeStartingAtDateTime.substring(0,10)}}</span></div>
                        {{else}}
                        <div class="match-table-time" style="text-align: center; font-size: 0.95em;"><span>{{:timeStartingAtDateTime.substring(0,16)}}</span></div>
                        {{/if}}
                    </a>
</div>
           
            <div class="match-table-td" style="width: 40%;padding:15px 10px;">
                <div class="match-table-team match-table-team-winner">
                    <figure><img src="{{:visitorTeam.logoPath}}" alt="" width="41" height="59" /></figure>
                    <span>{{:visitorTeam.name}}</span>
                </div>
            </div>
        </div>

    </script>

    <script src="/lib/views/league/fixture-of-round.min.js" type="text/javascript" charset="utf-8"></script>

}
