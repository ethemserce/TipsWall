<section class="section section-sm bg-gray-100">
    <div class="container">
        <div class="row row-50">
            <div class="col-lg-7 col-xl-8">
                <div class="row row-50">
                    <div class="col-12">
                        <!-- Heading Component-->
                        <article class="heading-component">
                            <div class="heading-component-inner">
                                <h5 class="heading-component-title">
                                    <img src="@Model.Country.Logo" alt="" width="24" height="24" /> @Model.Country.Name
                                </h5>
                                <span style="float:right;">  <img src="@Model.Logo" alt="" width="24" height="24" /> @Model.Name</span>
                            </div>
                        </article>
                        <article class="heading-component" style="margin-top:5px; border:none;">
                            <div class="heading-component-inner">
                                <h5 class="heading-component-title">
                                    @foreach (var season in Model.Seasons)
                                    {
                                        @if (season.CurrentSeason)
                                        {
                                            <input type="hidden" id="leagueId" value="@season.LeagueId" />
                                        }
                                    }
                                </h5>
                                <div class="heading-component-aside" id="divSeasonSelect">
                                    <ul class="list-inline list-inline-xs list-inline-middle">
                                        <li>
                                            <select id="selectSeasonId" class="select select-minimal" data-placeholder="Select an option" data-dropdown-class="select-minimal-dropdown">
                                                @foreach (var season in Model.Seasons)
                                                {
                                                    @if (season.CurrentSeason)
                                                    {
                                                        <option value="@season.Id" selected="selected">@season.Name</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@season.Id">@season.Name</option>
                                                    }
                                                }
                                            </select>
                                        </li>
                                        <li>
                                            <select id="selectStageId" class="select select-minimal" data-placeholder="Select an option" data-dropdown-class="select-minimal-dropdown" style="min-width: 170px;">
                                                @foreach (var season in Model.Seasons)
            {
                                                    @if (season.CurrentSeason)
                {
                                                        @foreach (var stage in season.Stages)
                    {
                                                            @if (stage.Id == season.CurrentStageId)
                        {
                                                                <option value="@(stage.Id +"_"+stage.GroupId)" selected="selected">@stage.Name</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@(stage.Id +"_"+stage.GroupId)">@stage.Name</option>
                                                            }
                                                        }
                                                    }
                                                }
                                            </select>
                                        </li>
                                        <li>
                                            <select id="selectRoundId" class="select select-minimal" data-placeholder="Select an option" data-dropdown-class="select-minimal-dropdown">
                                                @foreach (var season in Model.Seasons)
                                                {
                                                    @if (season.CurrentSeason)
                                                    {
                                                        @foreach (var stage in season.Stages)
                                                        {
                                                            if (stage.Id == season.CurrentStageId)
                                                            {
                                                                @*@if (stage.Rounds.Count > 1)
                                                                    {*@
                                                                @foreach (var round in stage.Rounds)
                                                                {
                                                                    if (round.Id == season.CurrentRoundId)
                                                                    {
                                                                        <option value="@round.Id" selected="selected">@round.Name</option>
                                                                    }
                                                                    else
                                                                    {
                                                                        <option value="@round.Id">@round.Name</option>
                                                                    }
                                                                }

                                                                //}
                                                            }
                                                        }
                                                    }
                                                }

                                            </select>
                                        </li>
                                    </ul>

                                </div>
                            </div>
                        </article>
                        <div class="tabs-custom tabs-horizontal tabs-corporate" id="tabs-shortcodes" style="border:none;">
                            <ul class="nav nav-tabs">
                                <li class="nav-item" role="presentation" style="border-top:1px solid #e1e1e1;"><a class="nav-link active" href="#tabs-fixture" data-toggle="tab" style="padding:7px; min-width:100px;">@SharedLocalizer.GetString("FixtureOfRound")</a></li>
                                <li class="nav-item" role="presentation" style="border-top:1px solid #e1e1e1;"><a class="nav-link" href="#tabs-standings" data-toggle="tab" style="padding:7px; min-width:100px;">@SharedLocalizer.GetString("Standings")</a></li>
                                <li class="nav-item" role="presentation" style="border-top:1px solid #e1e1e1;"><a class="nav-link" href="#tabs-topscorer" data-toggle="tab" style="padding:7px; min-width:100px;">@SharedLocalizer.GetString("TopScorer")</a></li>
                            </ul>
                            <div class="tab-content" style="padding:0px;">
                                <div class="tab-pane fade active show" id="tabs-fixture">
                                    <article class="game-result" style="border:none;">
                                        <div class="table-game-info-wrap" style="max-width:none;">
                                            <div class="row row-50">
                                                <div class="col-lg-12">
                                                    <!-- Match info-->
                                                    <div class="match-table-wrap">
                                                        <div class="match-table">
                                                            <div class="match-table-header">
                                                                <div class="match-table-tr">
                                                                    <div class="match-table-td" style="width: 40%;"><span>@SharedLocalizer.GetString("HomeTeam")</span></div>
                                                                    <div class="match-table-td" style="width: 20%; text-align:center;">@SharedLocalizer.GetString("Score")</div>
                                                                    <div class="match-table-td" style="width: 40%;"><span>@SharedLocalizer.GetString("AwayTeam")</span></div>
                                                                </div>
                                                            </div>
                                                            <div class="text-center" id="divLoading" style="display: none; padding-top:25px;">
                                                                <img src="/images/loading.gif" alt="loading" style="width: 25px;" />
                                                                <p class="game-info-subtitle" style="font-size:1.2em;">
                                                                    @SharedLocalizer.GetString("LoadingMatches")
                                                                </p>
                                                            </div>
                                                            <div class="match-table-body" id="divHomeTeamForms">

                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </article>
                                </div>
                                <div class="tab-pane fade" id="tabs-standings">
                                    <article class="game-result" style="border:none;">
                                        <div class="table-game-info-wrap" style="max-width:none;">
                                            <div class="card-standing card-group-custom card-standing-index" id="divStanding" role="tablist" aria-multiselectable="false">
                                                
                                                @if (Model != null && Model.LeagueStanding != null && Model.LeagueStanding.Count > 0)
                                                {
                                                <div class="card-standing-caption">
                                                    <div class="card-standing-position">@SharedLocalizer.GetString("Pos")</div>
                                                    <div class="card-standing-caption-aside">
                                                        <div class="card-standing-team">@SharedLocalizer.GetString("Team")</div>
                                                        <div class="card-standing-number">@SharedLocalizer.GetString("Mp")</div>
                                                        <div class="card-standing-number">@SharedLocalizer.GetString("WinShort")</div>
                                                        <div class="card-standing-number">@SharedLocalizer.GetString("DrawShort")</div>
                                                        <div class="card-standing-number">@SharedLocalizer.GetString("LostShort")</div>
                                                        <div class="card-standing-number">@SharedLocalizer.GetString("GoalScoreShort")</div>
                                                        <div class="card-standing-number">@SharedLocalizer.GetString("GoalAgainstShort")</div>
                                                        <div class="card-standing-points">@SharedLocalizer.GetString("PointShort")</div>
                                                        <div class="card-standing-diff">@SharedLocalizer.GetString("Average")</div>
                                                        <div class="card-standing-button" style="min-width: 42px;"></div>
                                                    </div>
                                                </div>
                                                @foreach (var standing in Model.LeagueStanding)
                                                    {
                                                <article class="card card-custom">
                                                    <div class="card-standing-position card-standing-counter"></div>
                                                    <div class="card-header" id="AH_@standing.StandingsPositon" role="tab">
                                                        <div class="card-standing-team-item">
                                                            <div class="card-standing-team">
                                                                <div class="card-standing-team-figure">
                                                                    <img src="@standing.Team.LogoPath" alt="" width="37" height="37" />
                                                                </div>
                                                                <div class="card-standing-team-title">
                                                                    <div class="card-standing-team-name">@standing.Team.Name.ToUpper()</div>
                                                                    <div class="card-standing-team-country">@standing.StandingsRecentForm</div>
                                                                </div>
                                                            </div>
                                                            <div class="card-standing-number">@standing.StandingsOverallGamesPlayed</div>
                                                            <div class="card-standing-number">@standing.StandingsOverallWon</div>
                                                            <div class="card-standing-number">@standing.StandingsOverallDraw</div>
                                                            <div class="card-standing-number">@standing.StandingsOverallLost</div>
                                                            <div class="card-standing-number">@standing.StandingsOverallGoalsScored</div>
                                                            <div class="card-standing-number">@standing.StandingsOverallGoalsAgainst</div>
                                                            <div class="card-standing-points">@standing.StandingsTotalPoints</div>
                                                            <div class="card-standing-diff">@standing.StandingsTotalGoalDifference</div>
                                                            <div class="card-standing-button"><a class="card-standing-toogle material-icons-remove collapsed" role="button" data-toggle="collapse" data-parent="#accordion1" href="#AC_@standing.StandingsPositon" aria-controls="AC_@standing.StandingsPositon"></a></div>
                                                        </div>
                                                    </div>
                                                    <div class="collapse" id="AC_@standing.StandingsPositon" role="tabpanel" aria-labelledby="AH_@standing.StandingsPositon">
                                                        <div class="card-body">
                                                            <div class="card-standing-team-details">
                                                                <div class="card-standing-team">@SharedLocalizer.GetString("Home")</div>
                                                                <div class="card-standing-number">@standing.StandingsHomeGamesPlayed</div>
                                                                <div class="card-standing-number">@standing.StandingsHomeWon</div>
                                                                <div class="card-standing-number">@standing.StandingsHomeDraw</div>
                                                                <div class="card-standing-number">@standing.StandingsHomeLost</div>
                                                                <div class="card-standing-number">@standing.StandingsHomeGoalsScored</div>
                                                                <div class="card-standing-number">@standing.StandingsHomeGoalsAgainst</div>
                                                                <div class="card-standing-points"></div>
                                                                <div class="card-standing-diff">@(standing.StandingsHomeGoalsScored - standing.StandingsHomeGoalsAgainst)</div>
                                                                <div class="card-standing-button" style="min-width:42px;">&nbsp;</div>
                                                            </div>
                                                            <div class="card-standing-divider"></div>
                                                            <div class="card-standing-team-details">
                                                                <div class="card-standing-team">@SharedLocalizer.GetString("Away")</div>
                                                                <div class="card-standing-number">@standing.StandingsAwayGamesPlayed</div>
                                                                <div class="card-standing-number">@standing.StandingsAwayWon</div>
                                                                <div class="card-standing-number">@standing.StandingsAwayDraw</div>
                                                                <div class="card-standing-number">@standing.StandingsAwayLost</div>
                                                                <div class="card-standing-number">@standing.StandingsAwayGoalsScored</div>
                                                                <div class="card-standing-number">@standing.StandingsAwayGoalsAgainst</div>
                                                                <div class="card-standing-points"></div>
                                                                <div class="card-standing-diff">@(standing.StandingsAwayGoalsScored - standing.StandingsAwayGoalsAgainst)</div>
                                                                <div class="card-standing-button" style="min-width:42px;">&nbsp;</div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </article>
                                                    }
                            <!-- Bootstrap card-->
                            <!-- Bootstrap card-->
                                                }
                                            </div>
                                        </div>
                                    </article>
                                </div>
                                <div class="tab-pane fade" id="tabs-topscorer">
                                    <article class="game-result" style="border:none;">
                                        <div class="table-game-info-wrap" style="max-width:none;">
                                            <div class="col-md-11 col-lg-10 col-xl-12" style="padding:0px;">
                                                @*<article class="heading-component">
                                                        <div class="heading-component-inner">
                                                            <h5 class="heading-component-title">
                                                                @SharedLocalizer.GetString("TopScorer")
                                                            </h5>
                                                        </div>
                                                    </article>*@
                                                <!-- Bootstrap tabs-->
                                                <div class="tabs-custom tabs-horizontal tabs-corporate" id="tabs-shortcodes">
                                                    <!-- Nav tabs-->
                                                    <ul class="nav nav-tabs">
                                                        <li class="nav-item" role="presentation"><a class="nav-link active" href="#tabs-shortcodes-1" data-toggle="tab">@SharedLocalizer.GetString("GoalScorers")</a></li>
                                                        <li class="nav-item" role="presentation"><a class="nav-link" href="#tabs-shortcodes-2" data-toggle="tab">@SharedLocalizer.GetString("AssistsScorers")</a></li>
                                                        <li class="nav-item" role="presentation"><a class="nav-link" href="#tabs-shortcodes-3" data-toggle="tab">@SharedLocalizer.GetString("CardScorers")</a></li>

                                                    </ul>
                                                    <!-- Tab panes-->
                                                    <div class="tab-content" style="padding:0px;">
                                                        <div class="tab-pane fade active show" id="tabs-shortcodes-1">
                                                            <div class="table-custom-responsive">
                                                                <table class="table-custom table-standings table-classic">
                                                                    <thead>
                                                                        <tr>
                                                                            <th colspan="2">@SharedLocalizer.GetString("Position")</th>
                                                                            <th>@SharedLocalizer.GetString("Goal")</th>
                                                                            <th>@SharedLocalizer.GetString("PenGoal")</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody id="tbodyGoalScorer">
                                                                        @if(Model != null && Model.TopScorers != null){
                                                                        @foreach (var goalScorer in Model.TopScorers.GoalScorer)
                                                                        {
                                                                        <tr>
                                                                            <td><span>@goalScorer.Position</span></td>
                                                                            <td class="team-inline">
                                                                                <div class="team-figure">
                                                                                    <img src="@goalScorer.Player.ImagePath" alt="" width="37" height="37">
                                                                                </div>
                                                                                <div class="team-title">
                                                                                    <div class="team-name">@goalScorer.Player.FullName</div>
                                                                                    <div class="team-country">@goalScorer.Team.Name</div>
                                                                                </div>
                                                                            </td>
                                                                            <td>@goalScorer.Goals</td>
                                                                            <td>@goalScorer.PenaltyGoals</td>
                                                                        </tr>
                                                                        }
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                        <div class="tab-pane fade" id="tabs-shortcodes-2">
                                                            <div class="table-custom-responsive">
                                                                <table class="table-custom table-standings table-classic">
                                                                    <thead>
                                                                        <tr>
                                                                            <th colspan="2">@SharedLocalizer.GetString("Position")</th>
                                                                            <th>@SharedLocalizer.GetString("Assists")</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody id="tbodyAssistsScorer">
                                                                        @if(Model != null && Model.TopScorers != null){
                                                                        @foreach (var assistsScorer in Model.TopScorers.AssistsScorer)
                                                                        {
                                                                        <tr>
                                                                            <td><span>@assistsScorer.Position</span></td>
                                                                            <td class="team-inline">
                                                                                <div class="team-figure">
                                                                                    <img src="@assistsScorer.Player.ImagePath" alt="" width="37" height="37">
                                                                                </div>
                                                                                <div class="team-title">
                                                                                    <div class="team-name">@assistsScorer.Player.FullName</div>
                                                                                    <div class="team-country">@assistsScorer.Team.Name</div>
                                                                                </div>
                                                                            </td>
                                                                            <td>@assistsScorer.Assists</td>
                                                                        </tr>
                                                                        }
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                        <div class="tab-pane fade" id="tabs-shortcodes-3">
                                                            <div class="table-custom-responsive">
                                                                <table class="table-custom table-standings table-classic">
                                                                    <thead>
                                                                        <tr>
                                                                            <th colspan="2">@SharedLocalizer.GetString("Position")</th>
                                                                            <th>@SharedLocalizer.GetString("YellowCards")</th>
                                                                            <th>@SharedLocalizer.GetString("RedCards")</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody id="tbodyCardScorer">
                                                                        @if(Model != null && Model.TopScorers != null){
                                                                        @foreach (var cardScorer in Model.TopScorers.CardScorer)
                                                                        {
                                                                        <tr>
                                                                            <td><span>@cardScorer.Position</span></td>
                                                                            <td class="team-inline">
                                                                                <div class="team-figure">
                                                                                    <img src="@cardScorer.Player.ImagePath" alt="" width="37" height="37">
                                                                                </div>
                                                                                <div class="team-title">
                                                                                    <div class="team-name">@cardScorer.Player.FullName</div>
                                                                                    <div class="team-country">@cardScorer.Team.Name</div>
                                                                                </div>
                                                                            </td>
                                                                            <td>@cardScorer.Yellowcards</td>
                                                                            <td>@cardScorer.Redcards</td>
                                                                        </tr>
                                                                        }
                                                                        }
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </article>
                                </div>
                            </div>
                        </div>

                    </div>
                    @if (Model.SeasonStats != null)
                    {
                        <div class="col-md-6 col-lg-6">
                            <div class="player-info-corporate player-info-other-team">
                                <div class="player-info-main">
                                    <h5 class="player-info-title" style="font-size:1.1em;">@SharedLocalizer.GetString("TeamWithMostGoals")</h5>
                                    <p class="player-info-subtitle">@Model.Name </p>
                                    <hr>
                                    <div class="player-info-table">
                                        <div class="table-custom-wrap">
                                            <table class="table-custom">
                                                <tbody>
                                                    <tr>
                                                        <td>
                                                            <div class="game-info-team game-info-team-second" style="width:100%;">
                                                                <figure>
                                                                    <img src="@Model.SeasonStats.TeamWithMostGoals.LogoPath" alt="" width="100" height="100">
                                                                </figure>
                                                                <div class="game-result-team-name" style="font-size:1.2em;">@Model.SeasonStats.TeamWithMostGoals.Name</div>
                                                                <div class="game-result-team-country" style="font-size:1.0em;">@Model.SeasonStats.TeamWithMostGoals.ShortCode</div>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-6">
                            <div class="player-info-corporate player-info-other-team">

                                <div class="player-info-main">
                                    <h5 class="player-info-title" style="font-size:1.1em;">@SharedLocalizer.GetString("TeamWithMostConcededGoals")</h5>
                                    <p class="player-info-subtitle">@Model.Name </p>
                                    <hr>
                                    <div class="player-info-table">
                                        <div class="table-custom-wrap">
                                            <table class="table-custom">
                                                <tbody>

                                                    <tr>
                                                        <td>
                                                            <div class="game-info-team game-info-team-second" style="width:100%;">
                                                                <figure>
                                                                    <img src="@Model.SeasonStats.TeamWithMostConcededGoals.LogoPath" alt="" width="100" height="100">
                                                                </figure>
                                                                <div class="game-result-team-name" style="font-size:1.2em;">@Model.SeasonStats.TeamWithMostConcededGoals.Name</div>
                                                                <div class="game-result-team-country" style="font-size:1.0em;">@Model.SeasonStats.TeamWithMostConcededGoals.ShortCode</div>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-6">
                            <div class="player-info-corporate player-info-other-team">

                                <div class="player-info-main">
                                    <h5 class="player-info-title" style="font-size:1.1em;">@SharedLocalizer.GetString("TeamWithMostGoalsPerMatch")</h5>
                                    <p class="player-info-subtitle">@Model.Name </p>
                                    <hr>
                                    <div class="player-info-table">
                                        <div class="table-custom-wrap">
                                            <table class="table-custom">
                                                <tbody>

                                                    <tr>
                                                        <td>
                                                            <div class="game-info-team game-info-team-second" style="width:100%;">
                                                                <figure>
                                                                    <img src="@Model.SeasonStats.TeamWithMostGoalsPerMatch.LogoPath" alt="" width="100" height="100">
                                                                </figure>
                                                                <div class="game-result-team-name" style="font-size:1.2em;">@Model.SeasonStats.TeamWithMostGoalsPerMatch.Name</div>
                                                                <div class="game-result-team-country" style="font-size:1.0em;">@Model.SeasonStats.TeamWithMostGoalsPerMatch.ShortCode</div>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-6">
                            <div class="player-info-corporate player-info-other-team">

                                <div class="player-info-main">
                                    <h5 class="player-info-title" style="font-size:1.1em;">@SharedLocalizer.GetString("TeamMostCleansheets")</h5>
                                    <p class="player-info-subtitle">@Model.Name </p>
                                    <hr>
                                    <div class="player-info-table">
                                        <div class="table-custom-wrap">
                                            <table class="table-custom">
                                                <tbody>
                                                    <tr>
                                                        <td>
                                                            <div class="game-info-team game-info-team-second" style="width:100%;">
                                                                <figure>
                                                                    <img src="@Model.SeasonStats.TeamMostCleansheets.LogoPath" alt="" width="100" height="100">
                                                                </figure>
                                                                <div class="game-result-team-name" style="font-size:1.2em;">@Model.SeasonStats.TeamMostCleansheets.Name</div>
                                                                <div class="game-result-team-country" style="font-size:1.0em;">@Model.SeasonStats.TeamMostCleansheets.ShortCode</div>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="col-lg-5 col-xl-4">
                <div class="block-aside-item">
                    <!-- Heading Component-->
                    <article class="heading-component">
                        <div class="heading-component-inner">
                            <h5 class="heading-component-title">
                                @SharedLocalizer.GetString("FollowUs")
                            </h5>
                        </div>
                    </article>

                    <!-- Buttons Media-->
                    <div class="group-sm group-flex">
                        <a class="button-media button-media-facebook" href="https://www.facebook.com/preodds">
                            <p class="button-media-action">@SharedLocalizer.GetString("Follow")<span class="icon material-icons-add_circle_outline icon-sm"></span></p><span class="button-media-icon fa-facebook"></span>
                        </a>
                        <a class="button-media button-media-twitter" href="https://twitter.com/preodds">
